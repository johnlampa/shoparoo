{
    "version": 2,
    "builds": [
        {
            "src": "backend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "backend/dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/backend/dist/$1"
        }
    ]
}
